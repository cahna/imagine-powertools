{
  "manifest_version": 3,
  "name": "Grok Imagine Power Tools",
  "description": "Power user features for Grok Imagine",
  "version": "1.0.0",
  "commands": {
    "resubmit-last": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "Alt+Shift+R"
      },
      "description": "Re-submit the most recent prompt for this post"
    },
    "submit-clipboard": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac": "Alt+Shift+P"
      },
      "description": "Submit prompt from clipboard"
    },
    "tab-left": {
      "suggested_key": {
        "default": "Alt+Shift+H",
        "mac": "Alt+Shift+H"
      },
      "description": "Switch to previous tab"
    },
    "tab-right": {
      "suggested_key": {
        "default": "Alt+Shift+L",
        "mac": "Alt+Shift+L"
      },
      "description": "Switch to next tab"
    },
    "video-6s": {
      "description": "Set video duration to 6 seconds"
    },
    "video-10s": {
      "description": "Set video duration to 10 seconds"
    },
    "video-480p": {
      "description": "Set video resolution to 480p"
    },
    "video-720p": {
      "description": "Set video resolution to 720p"
    },
    "video-spicy": {
      "description": "Set video mood to Spicy"
    },
    "video-fun": {
      "description": "Set video mood to Fun"
    },
    "video-normal": {
      "description": "Set video mood to Normal"
    },
    "download-video": {
      "description": "Download the current video"
    }
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://grok.com/imagine*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": []
}
